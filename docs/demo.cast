[9.74, "o", "  level   \u001b[1mL2 Standard\u001b[0m: existing patterns, \u22643 modules, testable criteria\r\n"]
[10.09, "o", "  route   \u001b[32m\u001b[1mSonnet \u00b7 medium effort\u001b[0m  \u001b[2m(not the session model)\u001b[0m\r\n"]
[10.44, "o", "  review  T2 \u00d7 L2 \u2192 spot-check only \u00b7 \u001b[2mno Codex, no gate ceremony\u001b[0m\r\n"]
[10.49, "o", "\r\n"]
[11.29, "o", "\u001b[35m\u23fa\u001b[0m Dispatching to Sonnet worker with the brief\u2026\r\n"]
